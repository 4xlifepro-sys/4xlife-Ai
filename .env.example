# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TWELVEDATA_API_KEY: Required for fetching real market data.
TWELVEDATA_API_KEY="MY_TWELVEDATA_API_KEY"

# SUPABASE CONFIGURATION
# Set these to persist signals and scanner stats to your Supabase project.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Client-side Supabase configuration (required for frontend authentication)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# TELEGRAM INTEGRATION
# Configure these to enable pushing Elite/Trade signals and System Alerts to Telegram channels.
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_DEFAULT_CHAT_ID="your-chat-id"
